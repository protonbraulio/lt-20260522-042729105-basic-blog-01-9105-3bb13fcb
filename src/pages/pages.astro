---
import { getCollection } from "astro:content";
import ListLayout from "../layouts/ListLayout.astro";
import { attachMeta } from "../utils/meta";

const pages = (await getCollection("projects", ({ data }) => data.draft !== true && data.pubDate <= new Date()))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .map((p) => attachMeta(p));
---

<ListLayout
    title="Pages"
    description="A collection of pages from Basic Blog Load Test 01 20260522-042729105."
    ogImage="https://lt-20260522-042729105-basic-blog-01-9105-3bb13fcb.pages.dev/images/og-default.svg"
    entries={pages}
/>
