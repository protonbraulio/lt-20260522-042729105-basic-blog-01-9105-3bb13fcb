---
import NewsletterForm from "../components/forms/NewsletterForm.astro";
import Container from "../components/layouts/Container.astro";
import PageTitle from "../components/ui/PageTitle.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Newsletter"
  description="Subscribe to Basic Blog Load Test 01 20260522-042729105 for new posts and project updates."
  ogImage="https://lt-20260522-042729105-basic-blog-01-9105-3bb13fcb.pages.dev/images/og-default.svg"
>
  <Container class="mx-auto max-w-2xl py-12">
    <PageTitle title="Newsletter" />
    <NewsletterForm
      variant="inline"
      showLegal={true}
      turnstileClass="flex justify-center"
    />
  </Container>
</BaseLayout>
